{{ 'editorial-theme.css' | asset_url | stylesheet_tag }}

<section class="ed-essay ed-section ed-section--reading color-{{ section.settings.color_scheme }}">
  <div class="ed-section__inner">
    {%- if section.settings.kicker != blank -%}
      <span class="kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="ed-heading ed-heading--display">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.lede != blank -%}
      <p class="ed-lede">{{ section.settings.lede }}</p>
    {%- endif -%}
    <div class="ed-essay__body rte">
      {%- if section.settings.body != blank -%}
        {{ section.settings.body }}
      {%- else -%}
        {{ page.content }}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .ed-essay__body { font-size: 18px; line-height: 1.6; }
  .ed-essay__body h2 { font-size: var(--fs-h2); margin-top: var(--space-7); margin-bottom: var(--space-4); }
  .ed-essay__body h3 { font-size: var(--fs-h3); margin-top: var(--space-6); margin-bottom: var(--space-3); }
  .ed-essay__body p { margin-bottom: var(--space-4); }
  .ed-essay__body ul, .ed-essay__body ol { margin: 0 0 var(--space-4); padding-left: var(--space-5); }
  .ed-essay__body li { margin-bottom: var(--space-2); }
  .ed-essay__body blockquote { border-left: 2px solid var(--accent); margin: var(--space-5) 0; padding-left: var(--space-4); color: var(--ink-muted); font-style: italic; }
</style>

{% schema %}
{
  "name": "Editorial essay",
  "tag": "section",
  "class": "ed-essay-section",
  "settings": [
    {"type": "text", "id": "kicker", "label": "Kicker"},
    {"type": "text", "id": "heading", "label": "Heading"},
    {"type": "textarea", "id": "lede", "label": "Lede"},
    {"type": "richtext", "id": "body", "label": "Body (leave blank to use page content)"},
    {"type": "select", "id": "color_scheme", "label": "Color scheme", "options": [
      {"value": "scheme-1", "label": "Primary"},
      {"value": "scheme-2", "label": "Alt"}
    ], "default": "scheme-1"}
  ],
  "presets": [{"name": "Editorial essay"}],
  "enabled_on": {"templates": ["page"]}
}
{% endschema %}
