{{ 'editorial-theme.css' | asset_url | stylesheet_tag }}

<section class="ed-member ed-section color-{{ section.settings.color_scheme }}">
  <div class="ed-section__inner">
    <div class="ed-member__grid">
      <div class="ed-member__heading">
        <span class="kicker">{{ section.settings.kicker | default: 'Membership' }}</span>
        <h2 class="ed-heading">{{ section.settings.heading }}</h2>
        <p class="ed-body ed-body--muted">{{ section.settings.body }}</p>
        {%- if section.settings.link_text != blank and section.settings.link_url != blank -%}
          <p><a class="editorial-link" href="{{ section.settings.link_url }}">{{ section.settings.link_text }} &rarr;</a></p>
        {%- endif -%}
      </div>
      <ol class="ed-member__steps">
        <li class="ed-member__step">
          <span class="ed-member__stepnum">I.</span>
          <div>
            <h3 class="ed-member__steptitle">Create an account.</h3>
            <p class="ed-body ed-body--muted">Free, with a single email. No newsletters.</p>
          </div>
        </li>
        <li class="ed-member__step">
          <span class="ed-member__stepnum">II.</span>
          <div>
            <h3 class="ed-member__steptitle">Enable notifications.</h3>
            <p class="ed-body ed-body--muted">Two messages per month. New essentials and price changes. Nothing else.</p>
          </div>
        </li>
        <li class="ed-member__step">
          <span class="ed-member__stepnum">III.</span>
          <div>
            <h3 class="ed-member__steptitle">Member pricing unlocks.</h3>
            <p class="ed-body ed-body--muted">Ten percent off every item, every time, applied at checkout.</p>
          </div>
        </li>
      </ol>
    </div>
  </div>
</section>

<style>
  .ed-member__grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: var(--space-8); align-items: start; }
  .ed-member__heading { max-width: 440px; }
  .ed-member__steps { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-5); }
  .ed-member__step { display: grid; grid-template-columns: 48px 1fr; gap: var(--space-4); border-top: 1px solid var(--rule); padding-top: var(--space-5); }
  .ed-member__step:first-child { border-top: 0; padding-top: 0; }
  .ed-member__stepnum { font-size: 22px; color: var(--accent); font-variant: small-caps; letter-spacing: var(--ls-kicker); }
  .ed-member__steptitle { font-size: var(--fs-h3); margin: 0 0 var(--space-2); }
  @media (max-width: 780px) {
    .ed-member__grid { grid-template-columns: 1fr; gap: var(--space-6); }
  }
</style>

{% schema %}
{
  "name": "Membership lockup",
  "tag": "section",
  "class": "ed-member-section",
  "settings": [
    {"type": "text", "id": "kicker", "label": "Kicker", "default": "Membership"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Members pay ten percent less."},
    {"type": "textarea", "id": "body", "label": "Body", "default": "Free to join. Requires an account and notification permission. No tiers, no games."},
    {"type": "text", "id": "link_text", "label": "Link text", "default": "How membership works"},
    {"type": "url", "id": "link_url", "label": "Link URL"},
    {"type": "select", "id": "color_scheme", "label": "Color scheme", "options": [
      {"value": "scheme-1", "label": "Primary"},
      {"value": "scheme-2", "label": "Alt"}
    ], "default": "scheme-1"}
  ],
  "presets": [{"name": "Membership lockup"}]
}
{% endschema %}
