{{ 'editorial-theme.css' | asset_url | stylesheet_tag }}

<section class="ed-pillars ed-section color-{{ section.settings.color_scheme }}">
  <div class="ed-section__inner">
    <div class="ed-pillars__header">
      {%- if section.settings.kicker != blank -%}
        <span class="kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      <h2 class="ed-heading">{{ section.settings.heading }}</h2>
    </div>
    <div class="ed-pillars__grid">
      {%- for block in section.blocks -%}
        <div class="ed-pillars__item" {{ block.shopify_attributes }}>
          <span class="ed-pillars__numeral">{{ forloop.index | append: '.' }}</span>
          <h3 class="ed-pillars__title">{{ block.settings.title }}</h3>
          <p class="ed-body ed-body--muted">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .ed-pillars__header { max-width: 620px; margin-bottom: var(--space-7); }
  .ed-pillars__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-7); border-top: 1px solid var(--rule); padding-top: var(--space-6); }
  .ed-pillars__item { padding-right: var(--space-4); }
  .ed-pillars__numeral { font-size: 32px; color: var(--accent); display: block; margin-bottom: var(--space-3); }
  .ed-pillars__title { font-size: var(--fs-h3); margin: 0 0 var(--space-3); }
  @media (max-width: 780px) {
    .ed-pillars__grid { grid-template-columns: 1fr; gap: var(--space-6); }
  }
</style>

{% schema %}
{
  "name": "Three pillars",
  "tag": "section",
  "class": "ed-pillars-section",
  "max_blocks": 3,
  "settings": [
    {"type": "text", "id": "kicker", "label": "Kicker", "default": "How we assess products"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Three questions we ask about every item."},
    {"type": "select", "id": "color_scheme", "label": "Color scheme", "options": [
      {"value": "scheme-1", "label": "Primary"},
      {"value": "scheme-2", "label": "Alt"}
    ], "default": "scheme-2"}
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {"type": "text", "id": "title", "label": "Title", "default": "Scientific backing"},
        {"type": "textarea", "id": "body", "label": "Body", "default": "Health items must have peer-reviewed evidence of a meaningful effect. Weak or mixed evidence gets rejected or labelled clearly."}
      ]
    }
  ],
  "presets": [
    {
      "name": "Three pillars",
      "blocks": [
        {"type": "pillar", "settings": {"title": "Scientific backing", "body": "Health items must have peer-reviewed evidence of a meaningful effect. Weak or mixed evidence is rejected or labelled clearly."}},
        {"type": "pillar", "settings": {"title": "Real-world usefulness", "body": "An item must solve a problem someone actually has. Novelty alone is not enough. Daily value over years is the test."}},
        {"type": "pillar", "settings": {"title": "Financial efficiency", "body": "Every item must offer clear value against its best alternative — whether that is a major brand, a recurring cost, or doing nothing."}}
      ]
    }
  ]
}
{% endschema %}
