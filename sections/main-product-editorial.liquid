{{ 'editorial-theme.css' | asset_url | stylesheet_tag }}
{{ 'editorial-product.css' | asset_url | stylesheet_tag }}
{{ 'editorial-comparison.css' | asset_url | stylesheet_tag }}
{{ 'editorial-evidence.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<section class="product-editorial color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
  <div class="product-editorial__gallery">
    {%- if product.media.size > 0 -%}
      {%- for media in product.media -%}
        <div class="product-editorial__gallery-item">
          {%- if media.media_type == 'image' -%}
            {%- if forloop.first -%}{%- assign loading = 'eager' -%}{%- else -%}{%- assign loading = 'lazy' -%}{%- endif -%}
            {{ media | image_url: width: 1600 | image_tag:
              loading: loading,
              sizes: '(min-width: 900px) 55vw, 100vw',
              widths: '400,600,800,1000,1200,1600',
              alt: media.alt | default: product.title
            }}
          {%- else -%}
            {{ media | media_tag: loading: 'lazy' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="product-editorial__content">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'header' -%}
          <header class="product-header" {{ block.shopify_attributes }}>
            {%- if product.collections.first -%}
              <span class="kicker">{{ product.collections.first.title }}</span>
            {%- endif -%}
            <h1 class="product-title">{{ product.title }}</h1>
            {%- assign subtitle = product.metafields.custom.functional_subtitle -%}
            {%- if subtitle != blank -%}
              <p class="product-subtitle">{{ subtitle }}</p>
            {%- endif -%}
            {% render 'member-state-block', product: product, variant: 'row' %}
            {% render 'product-form-minimal', product: product, section_id: section.id %}
            <p class="trust-line">{{ block.settings.trust_line }}</p>
          </header>

        {%- when 'why' -%}
          <section class="product-why" {{ block.shopify_attributes }}>
            <h2>{{ block.settings.heading | default: 'Why this is essential.' }}</h2>
            {%- assign what = product.metafields.custom.what_it_does -%}
            {%- assign why = product.metafields.custom.why_it_matters -%}
            {%- assign who = product.metafields.custom.who_benefits -%}
            {%- if what != blank -%}<p>{{ what }}</p>{%- endif -%}
            {%- if why != blank -%}<p>{{ why }}</p>{%- endif -%}
            {%- if who != blank -%}<p>{{ who }}</p>{%- endif -%}
            {%- if what == blank and why == blank and who == blank -%}
              <p class="ed-body ed-body--muted">Populate product metafields <code>custom.what_it_does</code>, <code>custom.why_it_matters</code>, and <code>custom.who_benefits</code> to display this section.</p>
            {%- endif -%}
          </section>

        {%- when 'comparison' -%}
          <div class="product-comparison" {{ block.shopify_attributes }}>
            {% render 'comparison-table', comparison: product.metafields.custom.comparison.value %}
          </div>

        {%- when 'evidence' -%}
          <div class="product-evidence" {{ block.shopify_attributes }}>
            {%- assign domain = product.metafields.custom.domain -%}
            {%- if domain == 'finance' or product.metafields.custom.financial_impact != blank -%}
              {% render 'financial-impact-panel', data: product.metafields.custom.financial_impact.value %}
            {%- else -%}
              {% render 'evidence-panel', evidence: product.metafields.custom.evidence.value %}
            {%- endif -%}
          </div>

        {%- when 'transparency' -%}
          <div class="product-transparency" {{ block.shopify_attributes }}>
            {% render 'transparency-mini-strip' %}
          </div>

        {%- when 'member' -%}
          <div class="product-member-lockup" {{ block.shopify_attributes }}>
            {% render 'member-state-block', product: product, variant: 'full' %}
          </div>

        {%- when 'best-for' -%}
          <div {{ block.shopify_attributes }}>
            {% render 'best-for-list', list: product.metafields.custom.best_for.value %}
          </div>

        {%- when 'caveats' -%}
          <div {{ block.shopify_attributes }}>
            {% render 'caveats-list', list: product.metafields.custom.caveats.value %}
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% schema %}
{
  "name": "Product (editorial)",
  "tag": "section",
  "class": "section",
  "settings": [
    {"type": "select", "id": "color_scheme", "label": "Color scheme", "options": [
      {"value": "scheme-1", "label": "Primary"},
      {"value": "scheme-2", "label": "Alt"}
    ], "default": "scheme-1"}
  ],
  "blocks": [
    {
      "type": "header",
      "name": "Header",
      "limit": 1,
      "settings": [
        {"type": "text", "id": "trust_line", "label": "Trust line", "default": "Ships in 2 days · Free over £60 · 2-year warranty"}
      ]
    },
    {
      "type": "why",
      "name": "Why this is essential",
      "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Why this is essential."}
      ]
    },
    {"type": "comparison", "name": "How it compares"},
    {"type": "evidence", "name": "Evidence / Impact"},
    {"type": "transparency", "name": "Pricing & warranty strip"},
    {"type": "member", "name": "Member pricing"},
    {"type": "best-for", "name": "Best for"},
    {"type": "caveats", "name": "What to know"}
  ]
}
{% endschema %}
