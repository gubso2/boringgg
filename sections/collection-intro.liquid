{{ 'editorial-theme.css' | asset_url | stylesheet_tag }}

<section class="ed-collection-intro ed-section ed-section--reading color-{{ section.settings.color_scheme }}">
  <div class="ed-section__inner">
    <nav class="ed-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      {%- if collection.metafields.custom.domain -%}
        <span aria-hidden="true">·</span>
        <a href="/collections/{{ collection.metafields.custom.domain }}">{{ collection.metafields.custom.domain | capitalize }}</a>
      {%- endif -%}
      <span aria-hidden="true">·</span>
      <span>{{ collection.title }}</span>
    </nav>

    {%- if section.settings.kicker != blank -%}
      <span class="kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    <h1 class="ed-heading ed-heading--display">{{ collection.title }}.</h1>

    {%- assign intro = collection.metafields.custom.editorial_intro | default: collection.description -%}
    {%- if intro != blank -%}
      <div class="ed-body ed-collection-intro__body">{{ intro }}</div>
    {%- endif -%}
  </div>
</section>

<style>
  .ed-collection-intro { padding-bottom: var(--space-6); }
  .ed-breadcrumb { font-size: 13px; color: var(--ink-muted); margin-bottom: var(--space-6); display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .ed-breadcrumb a { border-bottom: 0; color: var(--ink-muted); }
  .ed-breadcrumb a:hover { color: var(--ink); opacity: 1; }
  .ed-collection-intro__body { font-size: 19px; line-height: 1.55; max-width: 640px; margin-top: var(--space-4); }
  .ed-collection-intro__body p { margin-bottom: var(--space-4); }
</style>

{% schema %}
{
  "name": "Collection intro",
  "tag": "section",
  "class": "ed-collection-intro-section",
  "settings": [
    {"type": "text", "id": "kicker", "label": "Kicker"},
    {"type": "select", "id": "color_scheme", "label": "Color scheme", "options": [
      {"value": "scheme-1", "label": "Primary"},
      {"value": "scheme-2", "label": "Alt"}
    ], "default": "scheme-1"}
  ],
  "presets": [{"name": "Collection intro", "settings": {}}],
  "enabled_on": {"templates": ["collection"]}
}
{% endschema %}
